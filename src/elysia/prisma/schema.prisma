generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model ChartDataset {
    id         Int          @id @default(autoincrement())
    chartKey   String       @unique @db.VarChar(120)
    title      String       @db.VarChar(200)
    payload    Json
    rowCount   Int          @default(0)
    importedAt DateTime     @default(now())
    updatedAt  DateTime     @updatedAt
    points     ChartPoint[]

    @@index([importedAt])
}

model ChartPoint {
    id         Int      @id @default(autoincrement())
    chartKey   String   @db.VarChar(120)
    indexNo    Int
    data       Json
    importedAt DateTime @default(now())

    dataset ChartDataset @relation(fields: [chartKey], references: [chartKey], onDelete: Cascade)

    @@index([chartKey, indexNo])
    @@index([importedAt])
}
